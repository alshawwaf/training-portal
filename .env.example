# =============================================================================
# SE Training Portal - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# General Settings
# -----------------------------------------------------------------------------
ENV=development
FRONTEND_URL=http://localhost:9999

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# For development (SQLite):
DATABASE_URL=sqlite:///./sql_app.db

# For production (PostgreSQL):
# DATABASE_URL=postgresql://admin:password@localhost:5432/se_training_portal

# Docker PostgreSQL settings (used by docker-compose)
DB_USER=admin
DB_PASSWORD=password
DB_NAME=se_training_portal

# -----------------------------------------------------------------------------
# Azure Active Directory (Optional - for SSO)
# -----------------------------------------------------------------------------
# Create an App Registration in Azure Portal:
# https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_TENANT_ID=your-tenant-id-here

# -----------------------------------------------------------------------------
# Superadmin Local Authentication
# -----------------------------------------------------------------------------
# Used for development or emergency access without Azure AD
SUPERADMIN_EMAIL=admin@cpdemo.com
SUPERADMIN_PASSWORD=Cpwins!1

# -----------------------------------------------------------------------------
# Proxmox VE Configuration
# -----------------------------------------------------------------------------
PROXMOX_HOST=192.168.1.100
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=your-proxmox-password
PROXMOX_NODE=pve

# Set to 'true' to use mock data instead of real Proxmox connection
PROXMOX_MOCK=true

# -----------------------------------------------------------------------------
# pgAdmin (Optional - for database management)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
