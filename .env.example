# =============================================================================
# SE Training Portal - Environment Variables
# =============================================================================
ENV=development
FRONTEND_URL=http://localhost:8989

# Database
# Use absolute path for sqlite in Windows if needed, or postgres url
# DATABASE_URL=sqlite:///./sql_app.db
# Docker uses internal DNS 'db'
DATABASE_URL=postgresql://admin:password@db:5432/se_training_portal

DB_USER=admin
DB_PASSWORD=password
DB_NAME=se_training_portal

# Azure AD Configuration
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_TENANT_ID=your-tenant-id-here

# Superadmin (Local)
SUPERADMIN_EMAIL=admin@cpdemo.com
SUPERADMIN_PASSWORD=Cpwins!1

# pgAdmin
PGADMIN_EMAIL=admin@cpdemo.com
PGADMIN_PASSWORD=Cpwins!1

# Proxmox Configuration
PROXMOX_HOST=192.168.1.100
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=your-proxmox-password
PROXMOX_NODE=pve
PROXMOX_MOCK=true

# vSphere Configuration
VSPHERE_HOST=203.0.113.10
VSPHERE_USER=administrator@vsphere.local
VSPHERE_PASSWORD=your-vsphere-password
VSPHERE_PORT=443
VSPHERE_VERIFY_SSL=false
VSPHERE_MOCK=true

# --- Cloud Provider Defaults ---
# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Azure
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# GCP
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_JSON={}

# CloudShare
CLOUDSHARE_API_ID=
CLOUDSHARE_API_KEY=

# Skytap
SKYTAP_USERNAME=
SKYTAP_API_TOKEN=
