# ============================================================================
# SE Training Portal - Environment Configuration
# ============================================================================
# Copy this file to .env and customize your values
# Variables marked [REQUIRED] must be set for the application to work
# Variables marked [OPTIONAL] have defaults and can be omitted
# ============================================================================

# ============================================================================
# DATABASE
# ============================================================================
# [REQUIRED] PostgreSQL connection string
# Docker setup: Use 'db' as hostname (internal Docker network)
# Local dev: Use 'localhost' with your PostgreSQL port
DATABASE_URL=postgresql://admin:password@db:5432/training_portal

# ============================================================================
# SUPERADMIN ACCOUNT
# ============================================================================
# [REQUIRED] Initial admin account created on first startup
# ⚠️ Change these in production!
SUPERADMIN_EMAIL=admin@cpdemo.com
SUPERADMIN_PASSWORD=Cpwins!1

# ============================================================================
# FRONTEND
# ============================================================================
# [REQUIRED] Base URL for frontend (used in emails and OAuth redirects)
FRONTEND_URL=http://localhost:9999

# ============================================================================
# AUTHENTICATION
# ============================================================================
# [OPTIONAL] Azure AD SSO - leave empty to use local auth only
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# [OPTIONAL] Allowed email domains for registration (comma-separated)
# Users can only register with these domains
ALLOWED_DOMAINS=checkpoint.com,example.com

# ============================================================================
# GUACAMOLE (Browser Console)
# ============================================================================
# [REQUIRED] Secret key for Guacamole authentication (32-char hex)
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
GUACAMOLE_SECRET_KEY=REDACTED_GUACAMOLE_SECRET_KEY

# [OPTIONAL] Guacamole URLs (defaults work for Docker Compose setup)
GUACAMOLE_URL=http://guacamole:8080/guacamole
GUACAMOLE_EXTERNAL_URL=http://localhost:8085/guacamole

# ============================================================================
# INFRASTRUCTURE (OPTIONAL - Configure in UI instead)
# ============================================================================
# These are OPTIONAL fallback values for vSphere
# For production, use Settings > Infrastructure in the UI
VSPHERE_HOST=
VSPHERE_USER=administrator@vsphere.local
VSPHERE_PASSWORD=
VSPHERE_PORT=443
VSPHERE_VERIFY_SSL=false

# ============================================================================
# ADVANCED (OPTIONAL)
# ============================================================================
# [OPTIONAL] Logging level
LOG_LEVEL=INFO

# [OPTIONAL] Backend WebSocket URL for console connections
BACKEND_WS_URL=ws://localhost:8000

# [OPTIONAL] Provisioning mode: parallel or sequential
PROVISIONING_MODE=parallel

# ============================================================================
# NOTES
# ============================================================================
# Email/SMTP: Configure via Settings > Email in the UI
# Proxmox: Configure via Settings > Private Cloud in the UI
# vSphere: Configure via Settings > Private Cloud in the UI (recommended)
# ============================================================================
